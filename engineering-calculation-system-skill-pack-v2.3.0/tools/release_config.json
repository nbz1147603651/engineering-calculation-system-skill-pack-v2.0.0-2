{
  "version": "2.4.0",
  "created_at": "2026-06-17",
  "profiles": [
    "core",
    "adapters-light",
    "qoder-addon",
    "singlefile",
    "source-dev"
  ],
  "default_all_profiles": [
    "core",
    "adapters-light",
    "qoder-addon",
    "singlefile",
    "source-dev"
  ],
  "release_required_profiles": [
    "core",
    "adapters-light",
    "qoder-addon",
    "singlefile",
    "source-dev"
  ],
  "publish_targets": [
    "CODEX",
    "QODER",
    "QODER Project",
    "TRAE",
    "OpenCode"
  ],
  "source_dev_includes": [
    "core",
    "adapter_sources",
    "docs",
    "archive",
    "tools",
    ".gitignore"
  ],
  "singlefile_prefixes": [
    "SKILL.md",
    "agents/",
    "parent/",
    "skills/",
    "shared/",
    "templates/",
    "schemas/",
    "scripts/validate_artifacts.py",
    "project_template/engineering_calc_project/README.md",
    "project_template/engineering_calc_project/pyproject.toml",
    "project_template/engineering_calc_project/implementation/02_modules/module_asset_registry.csv",
    "project_template/engineering_calc_project/webapp/",
    "project_template/engineering_calc_project/apps/",
    "project_template/engineering_calc_project/data/formula_registry/",
    "project_template/engineering_calc_project/deploy/",
    "project_template/engineering_calc_project/release/",
    "project_template/engineering_calc_project/src/",
    "project_template/engineering_calc_project/tests/"
  ],
  "classified_targets": [
    {
      "name": "CODEX",
      "path": "CODEX/engineering-calculation-system",
      "install_text": "Copy this folder into your Codex skills directory.",
      "notes": [
        "Typical Windows target: `%USERPROFILE%/.codex/skills/engineering-calculation-system/`."
      ]
    },
    {
      "name": "QODER",
      "path": ".",
      "install_text": "Upload this zip directly from QODER's Skills / Install Skill flow.",
      "include_core": false,
      "payload_at_root": true,
      "include_install_guide": false,
      "copies": [
        {
          "profile": "qoder-addon",
          "source": ".qoder/skills/engineering-calc-system",
          "target": "."
        }
      ],
      "notes": [
        "This archive places SKILL.md at the zip root for QODER skill import compatibility."
      ]
    },
    {
      "name": "QODER Project",
      "path": "Qoder/copy-to-project-root",
      "install_text": "Copy the contents of this folder into the root of the QODER project.",
      "include_adapter_docs": true,
      "copies": [
        {
          "profile": "qoder-addon",
          "source": ".qoder",
          "target": ".qoder"
        }
      ],
      "notes": [
        "This directory already merges the core skill, shared adapter docs, and `.qoder/` files."
      ]
    },
    {
      "name": "TRAE",
      "path": "TRAE/copy-to-project-root",
      "install_text": "Copy the contents of this folder into the root of the TRAE project.",
      "include_adapter_docs": true,
      "copies": [
        {
          "profile": "adapters-light",
          "source": ".trae",
          "target": ".trae"
        }
      ],
      "notes": [
        "This directory already merges the core skill, shared adapter docs, and `.trae/` files."
      ]
    },
    {
      "name": "OpenCode",
      "path": "OpenCode/copy-to-project-root",
      "install_text": "Copy the contents of this folder into the root of the OpenCode project.",
      "include_adapter_docs": true,
      "copies": [
        {
          "profile": "adapters-light",
          "source": ".opencode",
          "target": ".opencode"
        }
      ]
    },
    {
      "name": "AGENTS Generic",
      "path": "AGENTS-generic/copy-to-project-root",
      "install_text": "Copy the contents of this folder into an AGENTS.md-compatible project root.",
      "include_adapter_docs": true,
      "copies": [
        {
          "profile": "adapters-light",
          "source": "AGENTS.md",
          "target": "AGENTS.md",
          "is_file": true
        },
        {
          "profile": "adapters-light",
          "source": ".agents",
          "target": ".agents"
        }
      ]
    }
  ]
}
