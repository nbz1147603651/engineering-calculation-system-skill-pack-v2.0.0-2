{
  "name": "engineering-calculation-system-opencode-plugin",
  "version": "0.5.0",
  "description": "OpenCode plugin and project templates for the Engineering Calculation System skill pack.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema.json": "./assets/engineering-calc-system.schema.json"
  },
  "bin": {
    "engineering-calc-opencode": "./dist/cli/index.js"
  },
  "files": [
    "assets",
    "dist",
    "templates",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "build:schema": "npm run build && node scripts/build-schema.mjs",
    "doctor:local": "node dist/cli/index.js doctor --target ..",
    "install:dry-run": "node dist/cli/index.js install --target .. --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node scripts/test.mjs",
    "install-project": "node scripts/install-project.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "keywords": [
    "opencode",
    "plugin",
    "engineering-calculation",
    "agent-skills"
  ],
  "license": "UNLICENSED",
  "skillPack": {
    "name": "engineering-calculation-system",
    "schemaVersion": "2.4.3",
    "pluginCompatibility": "opencode"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.7",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
